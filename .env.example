# Copy to .env (git-ignored) and adjust. These defaults match docker-compose.yml.

POSTGRES_USER=stacker
POSTGRES_PASSWORD=stacker
POSTGRES_DB=stacker

# In-network URLs (compose service hostnames). From the host, db is
# localhost:5432 and db-test is localhost:5433.
DATABASE_URL=postgresql+psycopg://stacker:stacker@db:5432/stacker
TEST_DATABASE_URL=postgresql+psycopg://stacker:stacker@db-test:5432/stacker_test

# MinIO root credentials double as the S3 credentials in dev.
MINIO_ROOT_USER=stacker
MINIO_ROOT_PASSWORD=stacker-secret-key
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=stacker
S3_SECRET_KEY=stacker-secret-key
S3_BUCKET=replays
S3_REGION=us-east-1

# Discord OAuth. Create an app at discord.com/developers → OAuth2, copy the
# Client ID/Secret, and register BOTH callback URLs under "Redirects":
#   http://localhost:8000/auth/callback/discord
#   https://api.stacker.tetrisatuci.org/auth/callback/discord
# The redirect URI is the *API* callback, not the frontend. Dev defaults keep the
# API bootable without a real app (login just won't work).
DISCORD_CLIENT_ID=dev-client-id
DISCORD_CLIENT_SECRET=dev-client-secret
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback/discord
# openssl rand -hex 32  — MUST be a real random value in prod.
JWT_SECRET=dev-jwt-secret-change-me
FRONTEND_ORIGIN=http://localhost:5173
# Session-cookie attributes (dev defaults shown). In PROD, where the frontend
# (stacker.tetrisatuci.org) and API (api.stacker.tetrisatuci.org) are different
# subdomains, the browser only sends the session cookie cross-site when it is
# SameSite=None AND Secure — so set these two, and serve the API over HTTPS:
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# uvicorn autoreload (file watcher). On for dev; leave UNSET to keep it. In prod
# set it empty (UVICORN_RELOAD=) to run a stable worker without the watcher.
# UVICORN_RELOAD=

# ---------------------------------------------------------------------------
# PROD example (api.stacker.tetrisatuci.org), for reference — do NOT commit real
# secrets. Set these on the server's .env:
#   DISCORD_CLIENT_ID=<real>
#   DISCORD_CLIENT_SECRET=<real>
#   DISCORD_REDIRECT_URI=https://api.stacker.tetrisatuci.org/auth/callback/discord
#   JWT_SECRET=<openssl rand -hex 32>
#   FRONTEND_ORIGIN=https://stacker.tetrisatuci.org
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
#   UVICORN_RELOAD=            # empty → no dev autoreload
# And build the frontend with:  VITE_API_URL=https://api.stacker.tetrisatuci.org
